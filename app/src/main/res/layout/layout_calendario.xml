<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calendario"
            android:textSize="24sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC" />

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/boton_proximo"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Proximo"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#6750A4"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/boton_atrasado"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Atrasado"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#6750A4"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/boton_completado"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Completado"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:backgroundTint="#6750A4"
            android:textColor="@color/white" />

    </LinearLayout>

    <!-- Lista de tareas -->
    <ListView
        android:id="@+id/lista_calendario"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <!-- Boton agregar -->
    <Button
        android:id="@+id/boton_agregar_tarea_calendario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="+ Agregar Tarea"
        android:textAllCaps="false" />

</LinearLayout>
