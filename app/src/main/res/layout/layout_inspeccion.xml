<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/fondo_tarjeta_inspeccion"
    android:padding="12dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="16dp">

    <!-- Titulo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inspección"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Nombre inspeccion -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NOMBRE INSPECCIÓN"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/campo_nombre_inspeccion"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/fondo_input_nota"
        android:gravity="center_vertical"
        android:hint="Ej: Revision de fugas"
        android:includeFontPadding="false"
        android:inputType="text"
        android:minHeight="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Descripcion -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DESCRIPCIÓN"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/campo_descripcion_inspeccion"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/fondo_input_nota"
        android:hint="Ej: Verificar conexiones, presion y ruido"
        android:includeFontPadding="false"
        android:inputType="textMultiLine"
        android:gravity="center_vertical"
        android:minHeight="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Fecha -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FECHA"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/texto_fecha_inspeccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/fondo_fecha_editable"
        android:clickable="true"
        android:contentDescription="Cambiar fecha"
        android:drawableEnd="@drawable/ic_editar_fecha"
        android:drawablePadding="8dp"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:padding="10dp"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#6750A4"
        android:layout_marginBottom="8dp" />

    <!-- Repetir cada -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REPETIR CADA"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <Spinner
        android:id="@+id/spinner_repetir_inspeccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/opciones_repeticion"
        android:padding="8dp" />

</LinearLayout>
